# E2E environment configuration — copy to .env.local and fill in values.
# .env.local is gitignored and never committed.

# Backend and frontend base URLs.
# Defaults match the scaffolded ports; adjust for your environment.
BACKEND_URL=http://localhost:@@BACKEND_PORT@@
FRONTEND_URL=http://localhost:@@FRONTEND_PORT@@

# Backend health endpoint path (used by the smoke gate).
HEALTH_PATH=@@HEALTH_PATH@@

# Set to true when running UI tests that mock auth via page.route().
# Prevents global-setup.ts from resetting the database.
SKIP_DB_RESET=true

# Optional: bearer token to inject into backend API requests (API/sandbox tests only).
# Leave blank to rely on mock auth in UI tests.
BYPASS_AUTH_TOKEN=
